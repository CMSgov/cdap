{
  "name": "aws-params-env-action",
  "version": "1.3.0",
  "private": false,
  "description": "GitHub Action to set workflow environment variables from values in AWS Parameter Store. Parameters of type SecureString are masked.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src",
    "package": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/index.js && npx legally --csv > dist/licenses.txt",
    "test": "jest",
    "all": "npm install & npm run format-check && npm run lint && npm test && npm run build && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "cmsgov/cdap.git",
    "directory": "actions/aws-params-env-action"
  },
  "keywords": [
    "actions",
    "aws",
    "parameters"
  ],
  "author": "Sean Fern",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@aws-sdk/client-ssm": "^3.1018.0"
  },
  "devDependencies": {
    "@actions/http-client": "^4.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@vercel/ncc": "^0.38.4",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.4.2",
    "jest-util": "^30.4.1",
    "js-yaml": "^4.3.0",
    "legally": "^3.5.10",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "undici": "^8.3.0",
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.2.2",
    "glob": "^13.0.6"
  }
}
