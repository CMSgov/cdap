{
  "name": "aws-params-env-action",
  "version": "1.2.5",
  "private": false,
  "description": "GitHub Action to set workflow environment variables from values in AWS Parameter Store. Parameters of type SecureString are masked.",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "lint": "eslint src",
    "package": "esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/client-ssm",
    "test": "jest",
    "all": "npm install & npm run format-check && npm run lint && npm test && npm run build && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "cmsgov/cdap.git",
    "directory": "actions/aws-params-env-action"
  },
  "keywords": [
    "actions",
    "aws",
    "parameters"
  ],
  "author": "Sean Fern",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@aws-sdk/client-ssm": "^3.1018.0"
  },
  "devDependencies": {
    "@actions/http-client": "^4.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vercel/ncc": "^0.38.3",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.1",
    "jest": "^29.7.0",
    "jest-util": "^30.3.0",
    "js-yaml": "^4.1.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "undici": "^6.21.0",
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.0.3",
    "glob": "^11.0.0"
  }
}
